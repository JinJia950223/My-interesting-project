int current_speed = 0;           // 當前速度
int current_direction = 0;       // 當前方向
unsigned long lastSerialTime = 0;
const unsigned long SERIAL_INTERVAL = 500; // 每500ms打印一次

// ============== Mode Variables ==============
// Mode 0: 普通模式
// Mode 1: 衝刺模式 (馬達速度加倍)
// Mode 2: 緩速模式 (馬達速度減半)
float speed_multiplier = 1.0;

void RemoteXY_Mode_event() {
  Serial.print("Mode changed to: ");
  Serial.println(RemoteXY.Mode);
  
  // 根據模式調整速度倍數
  switch(RemoteXY.Mode) {
    case 0:
      speed_multiplier = 1.0;
      Serial.println("Normal Mode");
      break;
    case 1:
      speed_multiplier = 1.5;  // 衝刺模式
      Serial.println("Sprint Mode (1.5x Speed)");
      break;
    case 2:
      speed_multiplier = 0.5;  // 緩速模式
      Serial.println("Slow Mode (0.5x Speed)");
      break;
    default:
      speed_multiplier = 1.0;
      break;
  }
}

void setup() 
{
  Serial.begin(115200);
  delay(1000);
  
  Serial.println("\n\n========== Racing Car System ==========");
  Serial.println("Version: STA Mode with RemoteXY");
  
  // ============== GPIO Setup ==============
  pinMode(back_motor_pwm, OUTPUT);
  pinMode(direction_motor_pwm, OUTPUT);
  pinMode(back_motor_dir, OUTPUT);
  pinMode(direction_motor_dir, OUTPUT);
  
  // 初始化馬達停止
  analogWrite(back_motor_pwm, 0);
  analogWrite(direction_motor_pwm, 0);
  digitalWrite(back_motor_dir, LOW);
  digitalWrite(direction_motor_dir, LOW);

  Serial.println("\nConnecting to WiFi Hotspot...");
  Serial.print("SSID: ");
  Serial.println(REMOTEXY_WIFI_SSID);
  
  RemoteXY_Init();  // 啟動並開始連線手機熱點
  
  RemoteXYEngine.addVariableEvent(RemoteXY.Mode, RemoteXY_Mode_event);

  EEPROM.begin(RemoteXYEngine.getEepromSize()); // init EEPROM
  
  Serial.println("RemoteXY Initialized!");
  
  // 等待連接
  int timeout = 20;
  while(WiFi.status() != WL_CONNECTED && timeout > 0) {
    delay(500);
    timeout--;
  }
  
  if(WiFi.status() == WL_CONNECTED) {
    Serial.print("WiFi Connected!");
    Serial.print(" | ESP32 IP: ");
    Serial.println(WiFi.localIP());
  } else {
    Serial.println("WiFi Connection Failed!");
  }
  
  Serial.println("=========================================");
  Serial.println("System Ready!\n");
}

int wifi_link() { 
  // 確認wifi連接狀態，回傳訊號強度: dB值
  if (WiFi.status() != WL_CONNECTED) {
    return 0; // 若沒連上手機，回傳 0
  }
  return WiFi.RSSI(); // 直接回傳與手機熱點連接的訊號強度 (例如 -50 dBm)
}

void speed(int speedValue) {
  // speedValue: -255 ~ 255
  // 負值 = 後退，正值 = 前進
  
  // 套用速度倍數
  speedValue = constrain((int)(speedValue * speed_multiplier), -255, 255);
  current_speed = speedValue;
  
  if(speedValue > 0) {
    // 前進
    digitalWrite(back_motor_dir, HIGH);
    analogWrite(back_motor_pwm, speedValue);
  } 
  else if(speedValue < 0) {
    // 後退
    digitalWrite(back_motor_dir, LOW);
    analogWrite(back_motor_pwm, -speedValue);
  } 
  else {
    // 停止
    analogWrite(back_motor_pwm, 0);
  }
}

void turn(int directionValue) {
  // directionValue: -255 ~ 255
  // 負值 = 左轉，正值 = 右轉
  
  current_direction = directionValue;
  
  if(directionValue > 0) {
    // 右轉
    digitalWrite(direction_motor_dir, HIGH);
    analogWrite(direction_motor_pwm, directionValue);
  } 
  else if(directionValue < 0) {
    // 左轉
    digitalWrite(direction_motor_dir, LOW);
    analogWrite(direction_motor_pwm, -directionValue);
  } 
  else {
    // 直行
    analogWrite(direction_motor_pwm, 0);
  }
}

