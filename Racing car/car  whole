  // float voltage = (rawValue / 4095.0) * 3.3 * 3;  // 假設分壓器比例為1:3
  // return voltage;
  
  // 目前使用固定值
  return 12.0;
}

void handleRemoteControl() {
  // 從 RemoteXY 取得搖桿數值並轉換為馬達控制信號
  
  // Joy2_y: 前後速度控制 (-100 ~ 100)
  int speedControl = map(RemoteXY.joy2_y, -100, 100, -255, 255);
  speed(speedControl);
  
  // Joy1_x: 左右轉向控制 (-100 ~ 100)
  int directionControl = map(RemoteXY.joy1_x, -100, 100, -255, 255);
  turn(directionControl);
  
  // 更新顯示速度 (0-50 km/h 範圍)
  RemoteXY.speed = map(abs(RemoteXY.joy2_y), 0, 100, 0, 50);
  
  // 更新電池電壓
  RemoteXY.Battery = readBatteryVoltage();
  
  // 更新連接狀態
  RemoteXY.connect = wifi_link();
}

void printSystemStatus() {
  // 打印系統狀態
  Serial.print("WiFi: ");
  if(WiFi.status() == WL_CONNECTED) {
    Serial.print("Connected | Signal: ");
    Serial.print(wifi_link());
    Serial.print(" dBm");
  } else {
    Serial.print("Disconnected");
  }
  
  Serial.print(" | Speed: ");
  Serial.print(current_speed);
  Serial.print(" | Direction: ");
  Serial.print(current_direction);
  Serial.print(" | Mode: ");
  Serial.print(RemoteXY.Mode);
  Serial.print(" (x");
  Serial.print(speed_multiplier);
  Serial.print(") | Battery: ");
  Serial.print(RemoteXY.Battery);
  Serial.println(" V");
}

void loop() 
{ 
  RemoteXYEngine.handler();
  
  // 處理遙控輸入
  handleRemoteControl();
  
  // 定期打印系統狀態
  unsigned long currentTime = millis();
  if(currentTime - lastSerialTime >= SERIAL_INTERVAL) {
    lastSerialTime = currentTime;
    printSystemStatus();
  }
}
